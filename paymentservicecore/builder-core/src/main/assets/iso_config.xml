<?xml version="1.0" encoding="utf-8"?>
<j8583-config>

    <!-- ================= 0810 ================= -->
    <parse type="0810">
        <field num="7"  type="NUMERIC" length="10"/>
        <field num="11" type="NUMERIC" length="6"/>
        <field num="32" type="LLVAR"   length="11"/>
        <field num="39" type="ALPHA"   length="2"/>
        <field num="70" type="NUMERIC" length="3"/>
        <field num="96"  type="ALPHA" length="8"/>
        <field num="125" type="LLLVAR"/>
        <field num="127" type="LLLVAR"/>
    </parse>

    <parse type="0800">
        <field num="7"  type="NUMERIC" length="10"/>
        <field num="11" type="NUMERIC" length="6"/>
        <field num="32" type="LLVAR" length="11"/> <!-- optional acquirer id -->
        <field num="39" type="ALPHA" length="2"/>   <!-- response code -->
        <field num="41" type="ALPHA" length="8"/>   <!-- terminal id -->
        <field num="70" type="NUMERIC" length="3"/> <!-- network management info code -->
        <field num="96" type="ALPHA" length="8"/>   <!-- key management / echo info -->
        <field num="125" type="LLLVAR"/> <!-- 36-char key -->
    </parse>

    <!-- ================= 0210 ================= -->
    <parse type="0210">
        <field num="2"  type="LLVAR"  length="19"/>
        <field num="3"  type="NUMERIC" length="6"/>
        <field num="4"  type="NUMERIC" length="12"/>
        <field num="7"  type="NUMERIC" length="10"/>
        <field num="11" type="NUMERIC" length="6"/>
        <field num="12" type="TIME"/>
        <field num="13" type="DATE4"/>
        <field num="15" type="DATE4"/>
        <field num="17" type="DATE4"/>
        <field num="18" type="NUMERIC" length="4"/>
        <field num="22" type="NUMERIC" length="3"/>
        <field num="32" type="LLVAR" length="11"/>
        <field num="35" type="LLVAR" length="37"/>
        <field num="37" type="ALPHA" length="12"/>
        <field num="38" type="ALPHA" length="6"/>
        <field num="39" type="ALPHA" length="2"/>
        <field num="41" type="ALPHA" length="8"/>
        <field num="42" type="ALPHA" length="15"/>
        <field num="43" type="ALPHA" length="40"/>
        <field num="48" type="LLLVAR" length="25"/>
        <field num="49" type="NUMERIC" length="3"/>
        <field num="54" type="LLLVAR" length="120"/>
        <field num="58" type="LLLVAR" length="11"/>
        <field num="111" type="LLLVAR" length="255"/>
        <field num="125" type="LLLVAR"/>
        <field num="127" type="LLLVAR" length="100"/>
    </parse>

    <!-- ================= 0230 ================= -->
    <parse type="0230">
        <field num="2"  type="LLBIN"/>
        <field num="3"  type="NUMERIC" length="6"/>
        <field num="4"  type="NUMERIC" length="12"/>
        <field num="11" type="NUMERIC" length="6"/>
        <field num="12" type="TIME"/>
        <field num="13" type="DATE4"/>
        <field num="22" type="NUMERIC" length="3"/>
        <field num="23" type="NUMERIC" length="3"/>
        <field num="24" type="NUMERIC" length="3"/>
        <field num="25" type="NUMERIC" length="2"/>
        <field num="37" type="ALPHA" length="12"/>
        <field num="38" type="ALPHA" length="6"/>
        <field num="39" type="ALPHA" length="2"/>
        <field num="41" type="ALPHA" length="8"/>
        <field num="42" type="ALPHA" length="15"/>
        <field num="48" type="LLLVAR"/>
        <field num="49" type="ALPHA" length="3"/>
        <field num="55" type="LLLBIN"/>
        <field num="60" type="LLLVAR"/>
        <field num="61" type="LLLVAR"/>
        <field num="62" type="LLLVAR"/>
        <field num="63" type="LLLVAR"/>
    </parse>

    <parse type="0510">
        <field num="7"  type="NUMERIC" length="10"/>
        <field num="11" type="NUMERIC" length="6"/>
        <field num="15" type="NUMERIC" length="4"/>
        <field num="32" type="LLVAR" length="11"/>
        <field num="66" type="NUMERIC" length="1"/>
        <field num="74" type="NUMERIC" length="10"/>
        <field num="75" type="NUMERIC" length="10"/>
        <field num="76" type="NUMERIC" length="10"/>
        <field num="77" type="NUMERIC" length="10"/>
        <field num="80" type="NUMERIC" length="10"/>
        <field num="81" type="NUMERIC" length="10"/>
        <field num="86" type="NUMERIC" length="16"/>
        <field num="87" type="NUMERIC" length="16"/>
        <field num="88" type="NUMERIC" length="16"/>
        <field num="89" type="NUMERIC" length="16"/>
        <field num="97" type="ALPHA" length="16"/>
        <field num="99" type="LLVAR" length="11"/>

    </parse>

    <parse type="0430">

        <!-- Mandatory fields -->
        <field num="2"  type="LLVAR" length="19"/>   <!-- PAN -->
        <field num="3"  type="NUMERIC" length="6"/>  <!-- Processing Code -->
        <field num="4"  type="NUMERIC" length="12"/> <!-- Amount -->
        <field num="7"  type="NUMERIC" length="10"/> <!-- Transmission DateTime -->
        <field num="11" type="NUMERIC" length="6"/>  <!-- STAN -->
        <field num="12" type="TIME"/>                <!-- Local Time hhmmss -->
        <field num="13" type="DATE4"/>               <!-- Local Date MMDD -->
        <field num="14" type="DATE4"/>               <!-- Expiry Date YYMM -->
        <field num="15" type="DATE4"/>               <!-- Settlement Date MMDD -->
        <field num="18" type="NUMERIC" length="4"/>  <!-- Merchant Type -->
        <field num="32" type="LLVAR"/>               <!-- Acquirer ID -->
        <field num="37" type="ALPHA" length="12"/>   <!-- RRN -->
        <field num="38" type="ALPHA" length="6"/>    <!-- Auth ID -->
        <field num="39" type="ALPHA" length="2"/>    <!-- Response Code -->
        <field num="41" type="ALPHA" length="8"/>    <!-- Terminal ID -->
        <field num="42" type="ALPHA" length="15"/>   <!-- Merchant ID -->
        <field num="43" type="ALPHA" length="40"/>   <!-- Merchant Name/Location -->

        <!-- Optional / LLLVAR fields -->
        <field num="48" type="LLLVAR" length="25"/>  <!-- Merchant/Bank Name -->
        <field num="49" type="NUMERIC" length="3"/>  <!-- Currency Code -->
        <field num="54" type="LLLVAR" length="120"/> <!-- Additional Amounts -->
        <field num="58" type="LLLVAR" length="10"/>  <!-- National POS Condition Code -->
        <field num="59" type="LLLVAR" length="17"/>  <!-- POS Geographic Data -->
        <field num="60" type="LLLVAR" length="25"/>  <!-- Advice/Reversal Reason -->
        <field num="90" type="NUMERIC" length="42"/> <!-- Original Data Elements -->
        <field num="111" type="LLLVAR" length="255"/> <!-- Additional Private Data -->
        <field num="125" type="LLLVAR"/>
        <field num="127" type="LLLVAR" length="100"/> <!-- Acquirer Trace Data -->

    </parse>


</j8583-config>
